import { FormEvent, useEffect, useState } from "react";
import { bindTaskVideo, createAccount, deleteAccount, getAccounts, getTaskVideos, launchLogin, syncAccount } from "./api";
import type { AccountSummary, TaskVideoRow } from "./types";
import "./styles.css";

const loginStatusLabels: Record<string, string> = {
  never_logged_in: "жңӘзҷ»еҪ?,
  waiting_scan: "зӯүеҫ…жү«з Ғ",
  active: "е·Ізҷ»еҪ?,
  expired: "зҷ»еҪ•еӨұж•Ҳ",
  error: "зҷ»еҪ•ејӮеёё"
};

const taskStatusLabels: Record<string, string> = {
  in_progress: "иҝӣиЎҢдё?,
  settling: "з»“з®—дё?,
  completed: "е·Іе®ҢжҲ?,
  paused: "е·ІжҡӮеҒ?,
  abnormal: "ејӮеёё",
  unknown: "жңӘзҹҘ"
};

const videoStatusLabels: Record<string, string> = {
  published: "е·ІеҸ‘её?,
  reviewing: "е®Ўж ёдё?,
  rejected: "е®Ўж ёжӢ’з»қ",
  private: "з§ҒеҜҶ",
  deleted: "е·ІеҲ йҷ?,
  unknown: "жңӘзҹҘ"
};

function formatNumber(value: number | null): string {
  return value === null ? "--" : value.toLocaleString("zh-CN");
}

function formatTime(value: string | null): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "--";
}

function formatErrorText(value: string | null): string {
  if (!value) {
    return "жңҖиҝ‘ж— й”ҷиҜҜ";
  }

  const firstLine = value.split("\n")[0]?.trim() ?? value;
  return firstLine.length > 120 ? `${firstLine.slice(0, 120)}...` : firstLine;
}

export default function App() {
  const [accounts, setAccounts] = useState<AccountSummary[]>([]);
  const [rows, setRows] = useState<TaskVideoRow[]>([]);
  const [displayName, setDisplayName] = useState("");
  const [selectedAccountId, setSelectedAccountId] = useState("");
  const [selectedStatus, setSelectedStatus] = useState("");
  const [busyId, setBusyId] = useState<string | null>(null);
  const [bindInputs, setBindInputs] = useState<Record<string, string>>({});
  const [message, setMessage] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);

  async function refreshAccounts() {
    setAccounts(await getAccounts());
  }

  async function refreshRows(accountId = selectedAccountId, status = selectedStatus) {
    setRows(await getTaskVideos({ accountId, status }));
  }

  async function refreshAll(accountId = selectedAccountId, status = selectedStatus) {
    const [accountList, taskRows] = await Promise.all([
      getAccounts(),
      getTaskVideos({ accountId, status })
    ]);
    setAccounts(accountList);
    setRows(taskRows);
  }

  useEffect(() => {
    void refreshAll();
  }, []);

  useEffect(() => {
    const hasPendingLogin = accounts.some((account) => account.loginStatus === "waiting_scan");
    if (!hasPendingLogin) {
      return;
    }

    const timer = window.setInterval(() => {
      void refreshAccounts();
    }, 3000);

    return () => window.clearInterval(timer);
  }, [accounts]);

  async function handleCreateAccount(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();
    if (!displayName.trim()) {
      setError("иҜ·иҫ“е…ҘиҙҰеҸ·еҗҚз§?);
      return;
    }

    setError(null);
    setMessage(null);
    await createAccount(displayName.trim());
    setDisplayName("");
    setMessage("иҙҰеҸ·е·ІеҲӣе»?);
    await refreshAll();
  }

  async function handleLaunchLogin(accountId: string) {
    setBusyId(accountId);
    setError(null);
    setMessage(null);
    try {
      await launchLogin(accountId);
      setMessage("е·Іжү“ејҖжү«з Ғзҷ»еҪ•зӘ—еҸЈпјҢиҜ·еңЁжөҸи§ҲеҷЁдёӯе®ҢжҲҗжҠ–йҹ?жҳҹеӣҫжү«з Ғ");
      await refreshAccounts();
    } catch (caught) {
      setError(caught instanceof Error ? caught.message : "зҷ»еҪ•зӘ—еҸЈеҗҜеҠЁеӨұиҙҘ");
    } finally {
      setBusyId(null);
    }
  }

  async function handleSync(accountId: string) {
    setBusyId(accountId);
    setError(null);
    setMessage(null);
    try {
      await syncAccount(accountId);
      setMessage("еҗҢжӯҘе®ҢжҲҗ");
      await refreshAll();
    } catch (caught) {
      setError(caught instanceof Error ? caught.message : "еҗҢжӯҘеӨұиҙҘ");
      await refreshAccounts();
    } finally {
      setBusyId(null);
    }
  }

  async function handleDeleteAccount(accountId: string, displayName: string) {
    const confirmed = window.confirm(`зЎ®и®ӨеҲ йҷӨиҙҰеҸ·вҖ?{displayName}вҖқеҗ—пјҹиҝҷдјҡеҗҢж—¶еҲ йҷӨиҜҘиҙҰеҸ·зҡ„жң¬ең°дјҡиҜқе’Ңе·ІйҮҮйӣҶж•°жҚ®гҖӮ`);
    if (!confirmed) {
      return;
    }

    setBusyId(accountId);
    setError(null);
    setMessage(null);
    try {
      await deleteAccount(accountId);
      const nextAccountId = selectedAccountId === accountId ? "" : selectedAccountId;
      setSelectedAccountId(nextAccountId);
      setMessage("иҙҰеҸ·е·ІеҲ йҷ?);
      await refreshAll(nextAccountId, selectedStatus);
    } catch (caught) {
      setError(caught instanceof Error ? caught.message : "еҲ йҷӨиҙҰеҸ·еӨұиҙҘ");
    } finally {
      setBusyId(null);
    }
  }

  async function handleBind(taskId: string) {
    const videoId = bindInputs[taskId]?.trim();
    if (!videoId) {
      setError("иҜ·иҫ“е…?videoId");
      return;
    }

    setError(null);
    setMessage(null);
    try {
      await bindTaskVideo(taskId, videoId);
      setMessage("з»‘е®ҡе·Ідҝқеӯ?);
      await refreshRows();
    } catch (caught) {
      setError(caught instanceof Error ? caught.message : "з»‘е®ҡеӨұиҙҘ");
    }
  }

  async function handleFilterChange(accountId: string, status: string) {
    setSelectedAccountId(accountId);
    setSelectedStatus(status);
    setError(null);
    await refreshRows(accountId, status);
  }

  return (
    <main className="page">
      <section className="hero">
        <div>
          <p className="eyebrow">жң¬ең°зҪ‘йЎө + жң¬ең°йҮҮйӣҶжңҚеҠЎ</p>
          <h1>жҠ–йҹіжҳҹеӣҫд»»еҠЎз»ҹи®Ў</h1>
          <p className="subtle">
            еұ•зӨәжҳҹеӣҫеҸЈеҫ„ж’ӯж”ҫйҮҸгҖҒеҪ“еүҚе®һйҷ…ж’ӯж”ҫйҮҸгҖҒе·®еҖјгҖҒи§Ҷйў‘зҠ¶жҖҒе’Ңд»»еҠЎзҠ¶жҖҒгҖ?          </p>
        </div>
        <div className="status-box">
          <span>иҙҰеҸ·ж•?/span>
          <strong>{accounts.length}</strong>
          <span>д»»еҠЎи§Ҷйў‘ж•?/span>
          <strong>{rows.length}</strong>
        </div>
      </section>

      {message ? <div className="message success">{message}</div> : null}
      {error ? <div className="message error">{error}</div> : null}

      <section className="panel">
        <div className="panel-header">
          <h2>иҙҰеҸ·йЎ?/h2>
        </div>

        <form className="account-form" onSubmit={handleCreateAccount}>
          <input
            value={displayName}
            onChange={(event) => setDisplayName(event.target.value)}
            placeholder="иҫ“е…ҘиҙҰеҸ·еҗҚз§°"
          />
          <button type="submit">ж–°еўһиҙҰеҸ·</button>
        </form>

        <div className="account-grid">
          {accounts.map((account) => (
            <article key={account.id} className="account-card">
              <div>
                <h3>{account.displayName}</h3>
                <p>{account.platform}</p>
                <p>зҷ»еҪ•зҠ¶жҖҒпјҡ{loginStatusLabels[account.loginStatus] ?? account.loginStatus}</p>
                <p>жңҖеҗҺеҗҢжӯҘпјҡ{formatTime(account.lastSyncAt)}</p>
                <p className="error-text" title={account.lastError ?? "жңҖиҝ‘ж— й”ҷиҜҜ"}>
                <button
                  type="button"
                  className="secondary"
                  onClick={() => handleDeleteAccount(account.id, account.displayName)}
                  disabled={busyId === account.id}
                >
                  ЙҫіэХЛәЕ
                </button>
                  {formatErrorText(account.lastError)}
                </p>
                {account.loginStatus === "waiting_scan" ? (
                  <p className="hint-text">жөҸи§ҲеҷЁе·Іжү“ејҖпјҢиҜ·жү«з Ғе®ҢжҲҗзҷ»еҪ•пјҢйЎөйқўдјҡиҮӘеҠЁеҲ·ж–°зҠ¶жҖҒгҖ?/p>
                ) : null}
              </div>
              <div className="account-actions">
                <button
                  type="button"
                  onClick={() => handleLaunchLogin(account.id)}
                  disabled={busyId === account.id}
                >
                  {account.loginStatus === "waiting_scan" ? "зӯүеҫ…жү«з Ғ" : "жү«з Ғзҷ»еҪ•"}
                </button>
                <button
                  type="button"
                  className="secondary"
                  onClick={() => handleSync(account.id)}
                  disabled={busyId === account.id || account.loginStatus === "waiting_scan"}
                >
                  жүӢеҠЁеҗҢжӯҘ
                </button>
              </div>
            </article>
          ))}
          {accounts.length === 0 ? <p className="empty">иҝҳжІЎжңүиҙҰеҸ·пјҢе…Ҳж–°еўһдёҖдёӘиҙҰеҸ·гҖ?/p> : null}
        </div>
      </section>

      <section className="panel">
        <div className="panel-header">
          <h2>д»»еҠЎи§Ҷйў‘йЎ?/h2>
          <div className="filters">
            <select
              value={selectedAccountId}
              onChange={(event) => handleFilterChange(event.target.value, selectedStatus)}
            >
              <option value="">е…ЁйғЁиҙҰеҸ·</option>
              {accounts.map((account) => (
                <option key={account.id} value={account.id}>
                  {account.displayName}
                </option>
              ))}
            </select>
            <select
              value={selectedStatus}
              onChange={(event) => handleFilterChange(selectedAccountId, event.target.value)}
            >
              <option value="">е…ЁйғЁд»»еҠЎзҠ¶жҖ?/option>
              {Object.entries(taskStatusLabels).map(([key, value]) => (
                <option key={key} value={key}>
                  {value}
                </option>
              ))}
            </select>
          </div>
        </div>

        <div className="table-wrap">
          <table>
            <thead>
              <tr>
                <th>иҙҰеҸ·</th>
                <th>и§Ҷйў‘ж Үйўҳ</th>
                <th>еҸ‘еёғж—¶й—ҙ</th>
                <th>жҳҹеӣҫд»»еҠЎ</th>
                <th>жҳҹеӣҫж’ӯж”ҫйҮ?/th>
                <th>еҪ“еүҚж’ӯж”ҫйҮ?/th>
                <th>е·®еҖ?/th>
                <th>и§Ҷйў‘зҠ¶жҖ?/th>
                <th>д»»еҠЎзҠ¶жҖ?/th>
                <th>жңҖеҗҺеҗҢжӯ?/th>
                <th>з»‘е®ҡ</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((row) => (
                <tr key={row.taskId}>
                  <td>{row.accountName}</td>
                  <td>{row.videoTitle ?? "--"}</td>
                  <td>{formatTime(row.publishedAt)}</td>
                  <td>{row.taskName}</td>
                  <td>{formatNumber(row.xingtuPlayCount)}</td>
                  <td>{formatNumber(row.actualPlayCount)}</td>
                  <td>{formatNumber(row.playDelta)}</td>
                  <td>{row.videoStatus ? (videoStatusLabels[row.videoStatus] ?? row.videoStatus) : "--"}</td>
                  <td>{taskStatusLabels[row.taskStatus] ?? row.taskStatus}</td>
                  <td>{formatTime(row.lastSyncedAt)}</td>
                  <td>
                    {row.videoId ? (
                      <span className="pill">{row.matchSource === "manual" ? "жүӢе·Ҙз»‘е®ҡ" : "иҮӘеҠЁеҢ№й…Қ"}</span>
                    ) : (
                      <div className="bind-box">
                        <input
                          value={bindInputs[row.taskId] ?? ""}
                          onChange={(event) =>
                            setBindInputs((current) => ({ ...current, [row.taskId]: event.target.value }))
                          }
                          placeholder="иҫ“е…Ҙ videoId"
                        />
                        <button type="button" className="secondary" onClick={() => handleBind(row.taskId)}>
                          з»‘е®ҡ
                        </button>
                      </div>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          {rows.length === 0 ? <p className="empty">еҪ“еүҚжІЎжңүд»»еҠЎи§Ҷйў‘ж•°жҚ®пјҢиҜ·е…ҲеҗҢжӯҘиҙҰеҸ·гҖ?/p> : null}
        </div>
      </section>
    </main>
  );
}
